# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to backend/.env and fill in the values.
# NEVER commit .env to source control.
# ============================================================

# --- Backend Server ---
BACKEND_PORT=8000

# --- Frontend origin (for CORS) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- SQLite database path (relative to backend root) ---
DB_PATH=./data/submissions.db

# --- SMTP Email Settings ---
# Use Mailtrap (https://mailtrap.io) or Ethereal (https://ethereal.email) for dev
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# --- Admin notification email ---
# All submission emails will be sent to this address
ADMIN_EMAIL=admin@yourcompany.com
